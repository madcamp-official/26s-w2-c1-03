# ============================================================
# trip and end — 저장소 공통 .gitignore (백엔드/루트 기준)
# frontend/(Flutter)는 자체 .gitignore + 플랫폼별 하위 .gitignore(android/ios/macos/linux/windows)를 따로 가지고 있다.
# ============================================================

# ------------------------------------------------------------
# 환경변수 — 실제 값은 .env.example처럼 예시만 커밋한다 (.env.example만 예외)
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# 인증서 / 키 파일 — Apple 로그인 .p8, DB SSL CA cert(DATABASE_SSL_CA_PATH),
# Firebase 서비스 계정 JSON 등. 파일명이 아니라 패턴/디렉터리로 방어해 새 시크릿이
# 추가돼도 자동으로 걸리게 한다.
# ------------------------------------------------------------
secrets/
*.pem
*.key
*.p8
*.p12
*.crt
*.jks
*.keystore

# ------------------------------------------------------------
# 사진 파이프라인 임시 버퍼(PHOTO_TEMP_BUFFER_DIR) — 사용자 사진 실물이 로컬에
# 잠깐 쌓이는 디렉터리다(API 명세서 §6). 개인정보라 절대 커밋되면 안 된다.
# ------------------------------------------------------------
tmp/

# ------------------------------------------------------------
# Node / NestJS
# ------------------------------------------------------------
node_modules/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
.eslintcache

# ------------------------------------------------------------
# Docker — 로컬 전용 오버라이드는 시크릿을 담기 쉬워 별도로 제외한다.
# 정식 Dockerfile / docker-compose.yml은 커밋 대상.
# ------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------
# 에디터 / OS
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
