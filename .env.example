# ============================================================
# trip and end — Backend(NestJS) 환경변수 예시
#
# 참고 문서:
#   - plan.md (DEVELOPMENT_PLAN) §2 스택, §3.2 config/ 모듈 구조, §7 DB, §8 JWT, §9 AI, §11 스토리지, §13 Phase 13(알림)
#   - API_명세서_2026-07-10_v1.md §0 공통사항, §1 인증, §6 보안 원칙
#   - AI_기반_여행_계획_및_기록_앱_기능명세서_2026-07-10_v2.md §5 소셜로그인, §8 개인정보 처리 정책
#
# 실제 값은 이 파일이 아니라 .env(gitignore 대상)에만 채운다.
# 이 파일은 Flutter 앱이 아닌 백엔드(NestJS) 기준이다 — 프론트의 Supabase anon key 등은 별도 관리.
# ============================================================

# ------------------------------------------------------------
# App — main.ts / common (전역 설정, CORS)
# ------------------------------------------------------------
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------
# Database — config/database.config.ts
# Supabase "Session Pooler"(Supavisor session mode). IPv4 환경에서도 접속 가능하고,
# 클라이언트-서버 커넥션이 세션 동안 1:1로 유지되어 Direct Connection과 동일하게
# prepared statement 등 세션 기능을 그대로 쓸 수 있다. 12개 테이블 마이그레이션
# 대상은 plan.md §7 참고.
#
# 형식: postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
#   (Supabase 대시보드 Connect 메뉴 → Session pooler 탭에서 그대로 복사)
# 주의: 사용자명이 Direct Connection과 다르게 "postgres.<project-ref>" 형태다(단순 "postgres" 아님).
# 커넥션도 세션 동안 백엔드를 점유하므로 풀 크기를 보수적으로 유지한다(database.config.ts의 extra.max).
# SSL: 기본은 인증서 체인 미검증(rejectUnauthorized=false)으로 빠르게 시작하되 전송은 암호화된다.
#   운영 전에는 DATABASE_SSL_CA_PATH로 대시보드에서 받은 루트 인증서를 지정해 완전 검증을 켤 것.
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL_CA_PATH=

# ------------------------------------------------------------
# JWT — config/jwt.config.ts (plan.md §8.1)
# Access 30분 / Refresh 30일, 재발급 시 rotation + 재사용 탐지
# Access/Refresh는 서로 다른 시크릿 사용 권장
# ------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------
# 소셜 로그인 — auth/strategies (API 명세서 §1)
# 애플 로그인은 이번 범위에서 제외 — 카카오/구글 2종만 지원
# ------------------------------------------------------------

# 카카오: 로그인 토큰 검증(kapi.kakao.com/v2/user/me)에만 사용. 장소 인기순 정렬은
# Kakao 로컬 API가 평점/리뷰수를 제공하지 않아(카카오 공식 정책) Google Places로 대체했다
# (아래 GOOGLE_PLACES_API_KEY 참고) — 이 키는 로그인 용도로만 남아 있다.
KAKAO_REST_API_KEY=

# 구글: idToken 검증 시 audience 비교용. Android용이 아니라 "웹 애플리케이션" 타입
# OAuth 클라이언트 ID여야 한다(프론트 GOOGLE_SERVER_CLIENT_ID와 반드시 같은 값).
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# OpenAI — config/openai.config.ts (plan.md §9)
# schedule/client(OpenAiScheduleClient)와 records/pipeline(PhotoCurationClient)에서 각각 사용
# 사진 선별은 이미지 입력이 필요하므로 vision 지원 모델이어야 함
# ------------------------------------------------------------
OPENAI_API_KEY=
# 기본값 https://api.openai.com/v1 — Azure/프록시/호환 엔드포인트를 쓸 때만 재정의
OPENAI_BASE_URL=https://api.openai.com/v1
# 스케줄 생성은 지리 추론(권역 묶기·동선 순서)이 필요해 mini 모델이 자주 실패한다 — gpt-4o 이상 권장
OPENAI_SCHEDULE_MODEL=gpt-4o
OPENAI_PHOTO_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# TourAPI — config/tourapi.config.ts
# 관광지 후보 추천(API 명세서 §2.2)의 1차 데이터 소스
# ------------------------------------------------------------
TOUR_API_SERVICE_KEY=
TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
# TourAPI(한국관광공사)는 국내 지역코드만 제공한다(§areaCode2 확인 완료) — 이번 Phase는
# 국내 여행만 지원(팀 결정, plan.md §16 참고).
#
# 관광지 집중률(방문 추이 예측) 빅데이터 서비스 — 후보를 방문 집중도 순으로 정렬하는 데 쓴다
# (장소별 Google 매칭 대체, 시군구당 1회 호출·일 1회 갱신이라 하루 단위 캐싱). 위 SERVICE_KEY를
# 공유하되 공공데이터포털에서 "관광지 집중률 방문자 추이 예측 정보" 서비스도 함께 활용신청해야 한다.
# 데이터는 공공누리 1유형(출처표시)이라 DB 저장·2차 가공·재배포가 허용된다.
TOUR_API_BIGDATA_BASE_URL=https://apis.data.go.kr/B551011/TatsCnctrRateService

# ------------------------------------------------------------
# Google Places API (New) — places/clients/google-places.client.ts
# TourAPI 후보를 인기순(평점×리뷰수)으로 정렬하기 위한 2차 데이터 소스.
# Kakao 로컬 API는 평점/리뷰수를 제공하지 않아(카카오 공식 정책, devtalk 확인) 대신 채택.
# Google Cloud Console(기존 Firebase 프로젝트 "tripandend" 재사용 가능) → API 및 서비스 →
# 라이브러리 → "Places API (New)" 활성화 → 사용자 인증 정보에서 발급.
# ------------------------------------------------------------
GOOGLE_PLACES_API_KEY=

# ------------------------------------------------------------
# Firebase — config/firebase.config.ts
# Storage(사진 영구 저장)와 알림(FCM/APNs 발송, notifications 모듈)이 Firebase Admin SDK
# 자격증명 하나를 함께 쓴다. Firebase 콘솔 → 프로젝트 설정 → 서비스 계정에서 발급.
# ------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# 최종 선택된 여행 기록 사진만 이 버킷에 영구 저장(record_photos, plan.md §11.2). 저장 시
# 암호화는 Google Cloud Storage 기본 제공(Google-managed key)이라 별도 설정이 필요 없다(API 명세서 §6).
# 값 형식 주의: 최근 생성 프로젝트의 기본 버킷은 `<projectId>.firebasestorage.app` 이다
# (구형 프로젝트의 `.appspot.com` 아님). 정확한 값은 google-services.json 의 storage_bucket 참조.
FIREBASE_STORAGE_BUCKET=tripandend.firebasestorage.app

# ------------------------------------------------------------
# 사진 파이프라인 임시 버퍼 — records/pipeline (API 명세서 §6, plan.md §11.2, §14)
# 단일 서버 배포 전제, 로컬 디스크에 pass-through 저장 + TTL 강제 삭제
# curate 비추천분/finalize 미선택분 폐기가 이 디렉터리 기준으로 이루어짐
# ------------------------------------------------------------
PHOTO_TEMP_BUFFER_DIR=./tmp/photo-buffer
PHOTO_TEMP_BUFFER_TTL_MINUTES=30
